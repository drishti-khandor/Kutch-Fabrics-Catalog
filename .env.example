# Copy this file to .env and fill in your values

# --- AI ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview

# --- AWS S3 (for model photos) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=eu-north-1
AWS_S3_BASE_URL=https://your_bucket.s3.eu-north-1.amazonaws.com

# --- Database (Neon/Render set DATABASE_URL automatically once configured) ---
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Set on the FRONTEND service only, pointing at the deployed backend ---
# BACKEND_URL=https://your-backend.onrender.com
